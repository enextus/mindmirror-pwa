{
  "scripts": {
    "start": "http-server . -p 8080 -c-1 --no-dir-listing",
    "start:open": "http-server . -p 8080 -c-1 --no-dir-listing -o",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "http-server": "^14.1.1",
    "jsdom": "^26.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
