{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "noEmit": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node", "vitest"],
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.js",
    "src/**/*.d.ts",
    "tests/**/*.js",
    "vitest.config.js",
    "eslint.config.js"
  ],
  "exclude": [
    "node_modules",
    "coverage",
    "vendor"
  ]
}
